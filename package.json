{
  "name": "runplayback-website-rebuild",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "backfill:all-articles": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/backfill-all-youtube-articles.mjs",
    "backfill:article-authors": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/backfill-article-authors.mjs",
    "backfill:articles": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/backfill-youtube-articles.mjs",
    "repair:article-images": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/repair-article-product-images.mjs",
    "youtube-descriptions:update": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/update-youtube-descriptions.mjs",
    "popular-videos:update": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/update-popular-videos.mjs",
    "dev": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem next dev",
    "build": "next build",
    "start": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem next start",
    "lint": "next lint",
    "import:video-stills": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/import-video-stills.mjs",
    "import:video-stills:ai": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/import-video-stills.mjs --ai-filenames",
    "process:video-stills": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/import-video-stills.mjs --process-queue",
    "rename:article-stills": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/rename-article-still-filenames.mjs",
    "rename:article-stills:ai": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node scripts/rename-article-still-filenames.mjs --ai-filenames",
    "backfill:affiliate-inline-links": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node --experimental-strip-types scripts/backfill-article-inline-affiliate-links.mjs",
    "audit:affiliate-inline-links": "NODE_EXTRA_CA_CERTS=/opt/homebrew/etc/openssl@3/cert.pem node --experimental-strip-types scripts/audit-affiliate-inline-links.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "typescript": "latest"
  }
}
